<%- include('partials/header.ejs') %>
<%- include('partials/navbar.ejs') %>

<div class="container mt-5 pt-5">
    <div class="py-3">
        <h5>Product Lists</h5>
        <hr>
        <div class="table-responsive">
            <table class="table">
                <% if (products.length > 0) {%>
                    <thead>
                        <tr>
                            <th scope="col">ID</th>
                            <th scope="col">Image</th>
                            <th scope="col">Product Name</th>
                            <th scope="col">Category</th>
                            <th scope="col">Price/Unit (Bath)</th>
                            <th scope="col">Stock</th>
                            <th scope="col">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% products.forEach((product, index) => { %>
                            <tr>
                                <th scope="row"><%= product.id%></th>
                                <td><img width="100" src="/uploads/<%= product.image%>" alt="<%= product.name%>"></td>
                                <th scope="row"><%= product.name%></th>
                                <th scope="row"><%= product.category%></th>
                                <th scope="row"><%= product.price%></th>
                                <th scope="row">
                                    <% if (product.stock == 0 || product.stock == null || product.stock == 'undefined') {  %>
                                        <p class="text-danger">Unstock</p>
                                    <% } else { %>
                                        <p><%= product.stock %></p>
                                    <% } %>
                                </th>
                                <th scope="row">
                                    <a href="/edit/<%= product.id %>" class="btn btn-warning">Edit</a>
                                    <a href="product/delete/<%= product.id %>" onClick="return confirm('Are you sure you want to delete this product?');" class="btn btn-danger">Delete</a>
                                    
                                </th>                
                            </tr>
                        <% }); %>
                    </tbody>
                <% } else { %>

                <% } %>
            </table>
        </div>
    </div>
</div>

<%- include('partials/footer.ejs') %>